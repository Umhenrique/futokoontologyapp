<owl:Class rdf:about="#AbsentStudent">
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Student"/>
        <owl:Class>
          <owl:complementOf>
            <owl:Restriction>
              <owl:onProperty rdf:resource="#hasAbsenceMotive"/>
              <owl:someValuesFrom rdf:resource="#ExcludedFactor"/>
            </owl:Restriction>
          </owl:complementOf>
        </owl:Class>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasDaysAbsent"/>
          <owl:someValuesFrom>
            <rdfs:Datatype>
              <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
              <owl:withRestrictions>
                <rdf:Description>
                  <rdf:first>
                    <rdf:Description>
                      <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">30</xsd:minInclusive>
                    </rdf:Description>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </owl:withRestrictions>
            </rdfs:Datatype>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:subClassOf rdf:resource="#Student"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
  <rdf:type rdf:resource="http://purl.org/nemo/gufo#Phase"/>
  <rdfs:label xml:lang="en">Absent Student</rdfs:label>
  <rdfs:label xml:lang="pt-br">Estudante Ausente</rdfs:label>
  <rdfs:label xml:lang="ja">不登校</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#AbsenceMotive">
  <rdfs:subClassOf rdf:resource="http://purl.org/nemo/gufo#Quality"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
  <rdf:type rdf:resource="http://purl.org/nemo/gufo#Kind"/>
  <rdfs:label xml:lang="en">Absence Motive</rdfs:label>
  <rdfs:label xml:lang="pt-br">Motivo da Ausência</rdfs:label>
  <rdfs:label xml:lang="ja">欠席理由</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#Document">
