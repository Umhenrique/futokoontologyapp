<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.com/school-ontology"
         xmlns="http://example.com/school-ontology#"
         xmlns:x_1.1="http://purl.org/dc/elements/1.1/">

<owl:Ontology rdf:about="http://example.com/school-ontology">
  <owl:imports rdf:resource="http://purl.org/nemo/gufo#/1.0.0"/>
  <x_1.1:creator rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Matheus Medeiros</x_1.1:creator>
  <x_1.1:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administrative Process for School Refusal Registration</x_1.1:title>
  <rdfs:comment xml:lang="pt">Ontologia do contexto escolar baseada em gUFO (Visão Geral + Avaliação de Recusa Escolar + Triagem e Intervenção).</rdfs:comment>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#comparativeAbsenceDuration">
  <rdfs:domain rdf:resource="#SchoolRefusalClassification"/>
  <rdfs:range rdf:resource="#AbsenceDuration"/>
  <rdfs:label xml:lang="en">comparative</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#comparativePsychosocial">
  <rdfs:domain rdf:resource="#SchoolRefusalClassification"/>
  <rdfs:range rdf:resource="#PsychosocialFactor"/>
  <rdfs:label xml:lang="en">comparative</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#deliveryTo">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#StudentRecord"/>
  <rdfs:range rdf:resource="#MEXT"/>
  <rdfs:label xml:lang="en">Delivery To</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#directorParticipatesInTrial">
  <rdfs:subPropertyOf rdf:resource="http://purl.org/nemo/gufo#participatedIn"/>
  <rdfs:domain rdf:resource="#Director"/>
  <rdfs:range rdf:resource="#DirectorsTrial"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#facilityOccursInSession">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
  <rdfs:domain rdf:resource="#AlternativeLearningSession"/>
  <rdfs:range rdf:resource="#LearningFacility"/>
  <rdfs:label xml:lang="en">Occurs IN</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasAbsenceMotive">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
  <rdfs:domain rdf:resource="#Student"/>
  <rdfs:range rdf:resource="#ExcludedFactor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#informedBy">
  <rdfs:subPropertyOf rdf:resource="http://purl.org/nemo/gufo#mediates"/>
  <rdfs:domain rdf:resource="#DigitalCheckupSOS"/>
  <rdfs:range rdf:resource="#TeamSchool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isComponentOfSchool">
  <rdfs:subPropertyOf rdf:resource="http://purl.org/nemo/gufo#isComponentOf"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
  <rdfs:domain rdf:resource="#TeamSchool"/>
  <rdfs:range rdf:resource="#School"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#isMemberOfTeamSchool">
  <rdfs:subPropertyOf rdf:resource="http://purl.org/nemo/gufo#isCollectionMemberOf"/>
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#SchoolCounselor"/>
        <rdf:Description rdf:about="#SchoolSocialWorker"/>
        <rdf:Description rdf:about="#Teacher"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="#TeamSchool"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#monitoredBy">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
  <rdfs:domain rdf:resource="#Student"/>
  <rdfs:range rdf:resource="#TeamSchool"/>
  <rdfs:label xml:lang="en">Monitored by</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#participatesInScreening">
  <rdfs:subPropertyOf rdf:resource="http://purl.org/nemo/gufo#participatedIn"/>
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Parent"/>
        <rdf:Description rdf:about="#SchoolCounselor"/>
        <rdf:Description rdf:about="#Student"/>
        <rdf:Description rdf:about="#Teacher"/>
        <rdf:Description rdf:about="#TeamSchool"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="#Screening"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#performs">
  <rdfs:subPropertyOf rdf:resource="http://purl.org/nemo/gufo#mediates"/>
  <rdfs:domain rdf:resource="#DigitalCheckupSOS"/>
  <rdfs:range rdf:resource="#Student"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#planCreatedInIntervention">
